# ============================================================
# Xuni Scheduling Platform - Environment Variables
# Copy to .env and fill in actual values
# ============================================================

# ---- Python ----
PYTHONUNBUFFERED=1

# ---- Server ----
HOST=0.0.0.0
PORT=8080
DEBUG=true

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scheduling_platform
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scheduling_platform

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Qdrant Vector Database ----
QDRANT_HOST=localhost
QDRANT_REST_PORT=6333

# ---- Alibaba Cloud Bailian AI (REQUIRED) ----
BAILIAN_API_KEY=

# ---- JWT ----
JWT_SECRET=xuni-scheduling-platform-secret-key-2026
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800
