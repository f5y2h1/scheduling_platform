# ============================================================
# Xuni Scheduling Platform - 环境变量配置
# 数据库服务 Docker Compose 模式
#
# 使用方式：
#   1. 启动数据库服务：  docker-compose up -d
#   2. IDE中启动后端：   用 PyCharm Run 'app.main'
#   3. 终端启动前端：    cd frontend && npm run dev
# ============================================================

# ---- PostgreSQL ----
DB_PASSWORD=postgres
DB_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Qdrant 向量数据库 ----
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334